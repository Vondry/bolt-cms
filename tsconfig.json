{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./assets/js/app/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["assets/js/**/*", "assets/js/**/*.vue", "tests/**/*.ts"]
}
