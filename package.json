    "clipboard": "^2.0.11",
    "codemirror": "^5.65.15",
    "dropzone": "^6.0.0-beta.2",
    "easymde": "^2.21.0",
    "flagpack-dart-sass": "^2.0.0",
    "hotkeys-js": "^4.0.4",
    "jquery": "^3.7.1",
    "locutus": "^3.0.25",
    "luxon": "^3.7.2",
    "mitt": "^3.0.1",
    "no-scroll": "^2.1.1",
    "node-vibrant": "^4.0.4",
    "pinia": "^3.0.4",
    "popper.js": "^1.16.1",
    "register-service-worker": "^1.7.2",
    "selectize": "^0.12.6",
    "terser": "^5.48.0",
    "tinycolor2": "^1.6.0",
    "vue": "^3.5.39",
    "vue-flatpickr-component": "^12.0.0",
    "vue-multiselect": "^3.5.0",
    "vue-trumbowyg": "^4.0.0",
    "vuedraggable": "^4.1.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-free": "^5.15.4",
    "@symfony/webpack-encore": "^7.1.0",
    "@testing-library/cypress": "^10.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-vue": "^6.0.7",
