    "jsdom": "^29.1.1",
    "pa11y-ci": "^4.0",
    "postcss": "^8.4.38",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.4",
    "regenerator-runtime": "^0.14.1",
    "sass": "^1.69.5",
    "sass-loader": "^17.0.0",
    "source-sans-pro": "^3.6.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.2.0",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-loader": "^17.4.2",
    "vue-tsc": "^3.3.6",
    "webpack": "^5.94.0",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5.2.6",
    "webpack-notifier": "^1.15.0",
    "webpackbar": "^7.0.0",
    "workbox-webpack-plugin": "^7.4.1"
  },
  "scripts": {
    "start": "encore dev-server --port=8234 --progress",
    "build": "npm run genversion && encore production --progress",
    "postbuild": "rm -f public/assets/fonts/*.ttf; rm -f public/assets/fonts/*.eot; rm -f public/assets/fonts/*.woff; rm -f public/assets/images/fa-*.svg",
    "build:stats": "encore production --progress --json > webpack_stats.json",
    "serve": "encore dev --watch",
    "lint": "eslint assets",
    "lint-fix": "eslint assets --fix",
    "stylelint": "stylelint 'assets/scss'",
    "stylelint-fix": "stylelint 'assets/scss' --fix",
    "csfix": "eslint assets --fix; stylelint 'assets/scss' --fix",
    "a11y:test:all": "pa11y-ci --config=tests/a11y/pa11yci.json",
    "a11y:test": "pa11y-ci",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "genversion": "genversion --es6 --semi assets/js/version.js",
    "cypress:ci": "cypress run --config-file=tests/cypress/cypress.config.ci.js --quiet",
    "typecheck": "vue-tsc --noEmit",
    "cypress:dev": "cypress run --config-file=tests/cypress/cypress.config.dev.js",
    "cypress:open": "cypress open --config-file=tests/cypress/cypress.config.dev.js",
    "format": "prettier --write \"assets/**/*.{js,vue,ts,scss,css}\" \"tests/**/*.{js,ts,vue}\"",
    "format:check": "prettier --check \"assets/**/*.{js,vue,ts,scss,css}\" \"tests/**/*.{js,ts,vue}\""
  },
  "browserslist": [
    "> 1%"
  ]
}
