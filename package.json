{
    "name": "bolt",
    "version": "6.1.3",
    "homepage": "https://boltcms.io",
    "author": "Bob den Otter <bob@twokings.nl> (https://boltcms.io)",
    "license": "MIT",
    "description": "Bolt 5 npm/javascript packages",
    "keywords": [
        "bolt",
        "cms",
        "php",
        "symfony",
        "vue",
        "content",
        "management",
        "system"
    ],
    "bugs": {
        "url": "https://github.com/bolt/core/issues"
    },
    "main": "webpack.config.js",
    "directories": {
        "tests": "tests"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/bolt/core.git"
    },
    "dependencies": {
        "@popperjs/core": "2.11.8",
        "axios": "^1.16.1",
        "baguettebox.js": "1.11.1",
        "bootstrap": "5.3.2",
        "browserslist": "4.28.1",
        "clipboard": "2.0.11",
        "codemirror": "5.65.16",
        "dropzone": "5.9.3",
        "flagpack-dart-sass": "1.4.0",
        "hotkeys-js": "3.13.3",
        "jquery": "3.7.1",
        "locutus": "3.0.25",
        "luxon": "1.28.1",
        "no-scroll": "2.1.1",
        "node-vibrant": "3.1.6",
        "popper.js": "1.16.1",
        "register-service-worker": "1.7.2",
        "selectize": "0.12.6",
        "stylelint-config-recommended-scss": "4.3.0",
        "stylelint-scss": "3.21.0",
        "terser": "4.8.1",
        "tinycolor2": "1.6.0",
        "vue": "2.7.16",
        "vue-easymde": "2.0.0",
        "vue-flatpickr-component": "8.1.8",
        "vue-multiselect": "2.1.8",
        "vue-router": "^3.6.5",
        "vue-trumbowyg": "3.6.2",
        "vuedraggable": "2.24.3",
        "vuex": "3.6.2",
        "zxcvbn": "4.4.2"
    },
    "devDependencies": {
        "@babel/core": "^7.23.2",
        "@babel/eslint-parser": "^7.28.6",
        "@babel/plugin-transform-regenerator": "^7.22.10",
        "@babel/plugin-transform-runtime": "^7.23.2",
        "@babel/polyfill": "^7.12.1",
        "@babel/preset-env": "^7.23.2",
        "@eslint/compat": "^2.0.5",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@fortawesome/fontawesome-free": "^5.15.4",
        "@symfony/webpack-encore": "^4.7.0",
        "@testing-library/cypress": "^10.1.0",
        "@vue/test-utils": "^1.3.6",
        "ajv-keywords": "^3.5.2",
        "autoprefixer": "^10.4.16",
        "babel-core": "^7.0.0-bridge.0",
        "babel-eslint": "^10.1.0",
        "babel-jest": "^25.5.1",
        "clean-webpack-plugin": "^4.0.0",
        "core-js": "^3.33.2",
        "cypress": "^15.8.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-cypress": "^6.3.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-standard": "^4.1.0",
        "eslint-plugin-vue": "^10.9.0",
        "file-loader": "^6.2.0",
        "genversion": "^2.3.1",
        "globals": "^17.5.0",
        "html-webpack-plugin": "^5.5.3",
        "jest": "^25.5.4",
        "jest-serializer-vue": "^2.0.2",
        "pa11y-ci": "^4.0",
        "postcss": "^8.5.10",
        "postcss-loader": "^8.2.1",
        "postcss-preset-env": "^11.2.1",
        "prettier": "^3.8.3",
        "regenerator-runtime": "^0.13.11",
        "sass": "^1.69.5",
        "sass-loader": "^14.2.1",
        "source-sans-pro": "^3.6.0",
        "stylelint": "^13.13.1",
        "stylelint-config-standard": "^19.0.0",
        "vue-eslint-parser": "^10.4.0",
        "vue-jest": "^3.0.7",
        "vue-loader": "^15.11.1",
        "vue-template-compiler": "2.7.16",
        "webpack-notifier": "^1.15.0",
        "webpackbar": "^7.0.0",
        "workbox-webpack-plugin": "^6.6.0"
    },
    "scripts": {
        "start": "encore dev-server --port=8234 --progress",
        "build": "npm run genversion && encore production --progress",
        "postbuild": "rm public/assets/fonts/*.ttf; rm public/assets/fonts/*.eot; rm public/assets/fonts/*.woff; rm public/assets/images/fa-*.svg",
        "build:stats": "encore production --progress --json > webpack_stats.json",
        "serve": "encore dev --watch",
        "lint": "eslint assets",
        "lint-fix": "eslint assets --fix",
        "stylelint": "stylelint 'assets/scss'",
        "stylelint-fix": "stylelint 'assets/scss' --fix",
        "csfix": "eslint assets --fix; stylelint 'assets/scss' --fix",
        "a11y:test:all": "pa11y-ci --config=tests/a11y/pa11yci.json",
        "a11y:test": "pa11y-ci",
        "prettier": "prettier . --write",
        "prettier-check": "prettier . --check",
        "test": "jest",
        "genversion": "genversion --es6 --semi assets/js/version.js",
        "cypress:ci": "cypress run --config-file=tests/cypress/cypress.config.ci.js --quiet",
        "cypress:dev": "cypress run --config-file=tests/cypress/cypress.config.dev.js",
        "cypress:open": "cypress open --config-file=tests/cypress/cypress.config.dev.js"
    },
    "overrides": {
        "eslint": "^9.39.4"
    },
    "browserslist": [
        "> 1%"
    ],
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "vue"
        ],
        "transform": {
            "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
            ".*\\.(vue)$": "<rootDir>/node_modules/vue-jest"
        },
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/assets/js/app/$1"
        },
        "snapshotSerializers": [
            "<rootDir>/node_modules/jest-serializer-vue"
        ]
    }
}
