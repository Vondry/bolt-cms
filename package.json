    "@vue/tsconfig": "^0.9.1",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.16",
    "clean-webpack-plugin": "^4.0.0",
    "core-js": "^3.33.2",
    "cypress": "^15.8.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-standard": "^4.1.0",
    "eslint-plugin-vue": "^10.9.2",
    "file-loader": "^6.2.0",
    "genversion": "^3.2.0",
    "globals": "^17.7.0",
